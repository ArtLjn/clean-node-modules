{
  "name": "@morningljn/clean-node-modules",
  "version": "1.0.0",
  "description": "Scan and clean node_modules safely on macOS - moves to Trash, never rm",
  "bin": {
    "cnm": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "node-modules",
    "clean",
    "cleanup",
    "trash",
    "macos",
    "cli",
    "disk-space",
    "interactive",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArtLjn/clean-node-modules.git"
  },
  "homepage": "https://github.com/ArtLjn/clean-node-modules#readme",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
